# Copy to bootstrap.local.env (gitignored) and set values for your environment.
#
# Usage:
#   cp bootstrap.local.env.example bootstrap.local.env
#   edit bootstrap.local.env
#   uv run st-bootstrap deploy
#
# AWS pusher is optional. Leave GUARDIAN_AWS_ACCOUNT empty to disable it.

# Optional: override default AWS pusher image
# GUARDIAN_PUSHER_AWS_IMAGE=guardian-pusher-aws:latest

# Optional: override default Guardian LoadBalancer runtime image used by pushers.
# GUARDIAN_LB_IMAGE=lb:latest

# Optional: override MonoFS edge load balancer image.
# MONOFS_LB_IMAGE=lb:latest

# Extra ports for user-facing services registered dynamically by lb-k8s-agent.
# Space-separated list of port numbers to expose on the monofs-external K8s
# Service and local port-forward (172.21.63.46:<port>).
# Default: 9191 (agent frontend) 8888 (vscode)
# LB_USER_SERVICE_PORTS=9191 8888

# Enable AWS pusher by setting your account ID.
# GUARDIAN_AWS_ACCOUNT=123456789012

# Optional AWS region filter handled by this worker (empty = all account regions)
GUARDIAN_AWS_REGION=us-east-1

# Optional explicit pusher name; defaults to aws-${GUARDIAN_AWS_ACCOUNT}
# GUARDIAN_AWS_PUSHER_NAME=aws-123456789012

# Optional role name assumed by the AWS pusher
GUARDIAN_AWS_ASSUME_ROLE_NAME=GuardianCdkDeployRole

# Optional override for the managed MonoFS kubectl port-forward bind address.
# Defaults to 0.0.0.0 so localhost and the host LAN IP can both reach
# MonoFS/Guardian. Set 127.0.0.1 if you want loopback-only exposure instead.
# MONOFS_PORT_FORWARD_ADDRESS=127.0.0.1

# Optional explicit external IP(s) for bootstrap Services. Useful on bare-metal
# or WSL/home-lab setups with no LoadBalancer controller, where you want
# monofs-external / guardian-ui-external to publish a real host IP such as eth0.
# Comma-separate multiple addresses if needed; the first one is used for stamped
# URLs.
# EXTERNAL_SERVICE_IP=172.21.63.46
# EXTERNAL_SERVICE_IPS=172.21.63.46
