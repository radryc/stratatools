# Copy to bootstrap.local.env (gitignored) and set values for your environment.
#
# Usage:
#   cp bootstrap.local.env.example bootstrap.local.env
#   edit bootstrap.local.env
#   uv run st-bootstrap deploy
#
# AWS pusher is optional. Leave GUARDIAN_AWS_ACCOUNT empty to disable it.

# Optional: override default AWS pusher image
# GUARDIAN_PUSHER_AWS_IMAGE=guardian-pusher-aws:latest

# Enable AWS pusher by setting your account ID.
# GUARDIAN_AWS_ACCOUNT=123456789012

# Optional AWS region filter handled by this worker (empty = all account regions)
GUARDIAN_AWS_REGION=us-east-1

# Optional explicit pusher name; defaults to aws-${GUARDIAN_AWS_ACCOUNT}
# GUARDIAN_AWS_PUSHER_NAME=aws-123456789012

# Optional role name assumed by the AWS pusher
GUARDIAN_AWS_ASSUME_ROLE_NAME=GuardianCdkDeployRole

# Optional local devdns / dev hostname routing settings for `st-bootstrap --dns`.
# For LAN-wide `.strata` DNS, run devdns on one reachable host, set
# DEVDNS_SERVER_IP to that host's LAN IP, bind DNS/proxy on 0.0.0.0, and point
# your router or clients at that host as their DNS server. Binding port 53 and
# port 80 usually requires either root or:
#   sudo setcap cap_net_bind_service=+ep ~/bin/devdns
# If you leave DEVDNS_DNS_ADDR at 127.0.0.1:5353, devdns still works for local
# tooling, but that is not enough for whole-network wildcard `.strata` DNS.
# If you cannot bind port 80, set DEVDNS_PROXY_ADDR to a high port and the URL
# becomes http://doctor.strata:<port> instead.
# DEVDNS_DOMAIN=strata
# DEVDNS_SERVER_IP=192.168.1.50
# DEVDNS_DNS_ADDR=0.0.0.0:53
# DEVDNS_PROXY_ADDR=0.0.0.0:80
# DEVDNS_ADMIN_ADDR=127.0.0.1:10090
# DEVDNS_PORT_START=11080
# DEVDNS_PORT_END=11180
