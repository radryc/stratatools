# MonoFS Docker Compose Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Generate a 32-byte encryption key:
#   openssl rand -hex 32

# =============================================================================
# REQUIRED: Encryption Key
# =============================================================================
# 32-byte hex-encoded encryption key for packager archives.
# Used by fetchers (blob storage) and routers (archive creation during ingestion).
# ALL services must use the same key.
MONOFS_ENCRYPTION_KEY=

# =============================================================================
# Optional: S3/MinIO Configuration (for S3-enabled fetcher deployments)
# =============================================================================
# Uncomment and configure these to store archives in S3-compatible storage
# instead of local disk.

# MONOFS_S3_REGION=us-east-1
# MONOFS_S3_BUCKET=monofs
# MONOFS_S3_PREFIX=archives/
# MONOFS_S3_ENDPOINT=http://minio:9000
# MONOFS_S3_ACCESS_KEY_ID=minioadmin
# MONOFS_S3_SECRET_ACCESS_KEY=minioadmin
# MONOFS_S3_USE_PATH_STYLE=true

# =============================================================================
# Optional: Fetcher Configuration
# =============================================================================
# MONOFS_FETCHER_PORT=9200
# MONOFS_FETCHER_CACHE_DIR=/data/cache
# MONOFS_FETCHER_LOG_LEVEL=info

# =============================================================================
# Optional: Router Peering Configuration
# =============================================================================
# ROUTER1_PEERS=router2=http://router2:8080
# ROUTER2_PEERS=router1=http://router1:8080

# =============================================================================
# Optional: Build Version Overrides
# =============================================================================
# GIT_VERSION=dev
# GIT_COMMIT=unknown
# BUILD_TIME=unknown
