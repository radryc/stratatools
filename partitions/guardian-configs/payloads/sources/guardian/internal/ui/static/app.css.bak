/* Guardian UI — design tokens are declared later in this file (ArgoCD-inspired) */

* {
    box-sizing: border-box;
}

html, body {
    margin: 0;
    min-height: 100%;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Inter", sans-serif;
    color: var(--text-primary);
    background: var(--bg-base, #0d1117);
}

button, input, textarea, select {
    font: inherit;
}

button {
    cursor: pointer;
}

::-webkit-scrollbar {
    width: 10px;
    height: 10px;
}

::-webkit-scrollbar-track {
    background: rgba(15, 23, 42, 0.45);
}

::-webkit-scrollbar-thumb {
    background: rgba(148, 163, 184, 0.3);
    border-radius: 999px;
}

.layout {
    display: flex;
    min-height: 100vh;
}

.sidebar {
    position: fixed;
    inset: 0 auto 0 0;
    width: 290px;
    padding: 24px 16px;
    background: rgba(15, 23, 42, 0.88);
    border-right: 1px solid var(--border);
    backdrop-filter: blur(18px);
    overflow-y: auto;
}

.logo {
    padding: 8px 12px 18px;
    margin-bottom: 18px;
    border-bottom: 1px solid var(--border);
}

.logo-mark {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(109, 94, 252, 0.35), rgba(20, 184, 166, 0.35));
    border: 1px solid rgba(109, 94, 252, 0.35);
    margin-bottom: 10px;
    font-size: 22px;
    box-shadow: 0 12px 24px var(--shadow);
}

.logo h1 {
    margin: 0;
    font-size: 22px;
    font-weight: 800;
    background: linear-gradient(135deg, #c7d2fe 0%, #5eead4 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}

.logo p {
    margin: 6px 0 0;
    color: var(--text-secondary);
    font-size: 12px;
}

.nav {
    display: grid;
    gap: 8px;
    margin-bottom: 24px;
}

.nav-item,
.tab-button,
.action-button,
.ghost-button {
    border: 1px solid transparent;
    border-radius: 12px;
    transition: all 0.2s ease;
}

.nav-item {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    color: var(--text-secondary);
    background: transparent;
}

.nav-item:hover,
.nav-item.active {
    color: var(--text-primary);
    background: linear-gradient(135deg, rgba(109, 94, 252, 0.28), rgba(20, 184, 166, 0.22));
    border-color: rgba(109, 94, 252, 0.32);
}

.nav-icon {
    width: 20px;
    text-align: center;
}

.sidebar-section {
    margin-bottom: 22px;
}

.sidebar-heading {
    margin-bottom: 10px;
    color: var(--text-secondary);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
}

.search-shell {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
}

.search-input,
.builder-input,
.builder-textarea,
.builder-select {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px 12px;
    color: var(--text-primary);
    background: rgba(15, 23, 42, 0.72);
    outline: none;
}

.search-input:focus,
.builder-input:focus,
.builder-textarea:focus,
.builder-select:focus {
    border-color: rgba(109, 94, 252, 0.6);
    box-shadow: 0 0 0 3px rgba(109, 94, 252, 0.18);
}

.search-input.narrow {
    min-width: 220px;
}

.ghost-button,
.action-button {
    padding: 10px 14px;
    font-weight: 600;
    color: var(--text-primary);
    background: linear-gradient(135deg, rgba(109, 94, 252, 0.2), rgba(20, 184, 166, 0.15));
    border-color: rgba(109, 94, 252, 0.25);
}

.ghost-button:hover,
.action-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px var(--shadow);
}

.action-button.secondary,
.ghost-button {
    background: rgba(148, 163, 184, 0.08);
    border-color: var(--border);
}

.sidebar-footer {
    border-top: 1px solid var(--border);
    padding-top: 18px;
}

.sidebar-footer .action-button {
    width: 100%;
    margin-top: 8px;
}

.partition-list {
    display: grid;
    gap: 8px;
}

.partition-list-item {
    padding: 12px;
    background: rgba(15, 23, 42, 0.55);
    border: 1px solid var(--border);
    border-radius: 14px;
    cursor: pointer;
}

.partition-list-item.active,
.partition-list-item:hover {
    border-color: rgba(109, 94, 252, 0.45);
    background: rgba(31, 41, 55, 0.9);
}

.partition-list-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
}

.partition-list-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--text-secondary);
}

.main {
    margin-left: 290px;
    flex: 1;
    padding: 28px;
}

.header {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: flex-start;
    margin-bottom: 24px;
}

.eyebrow {
    margin: 0 0 6px;
    color: var(--secondary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 12px;
    font-weight: 700;
}

.header h1 {
    margin: 0 0 8px;
    font-size: 34px;
}

.header p {
    margin: 0;
    color: var(--text-secondary);
}

.header-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: flex-start;
}

.header-context-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.summary-grid,
.grid {
    display: grid;
    gap: 20px;
}

.summary-grid {
    grid-template-columns: repeat(6, minmax(0, 1fr));
    margin-bottom: 24px;
}

.two-col {
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
}

.builder-grid {
    grid-template-columns: minmax(260px, 0.7fr) minmax(0, 1.6fr) minmax(300px, 0.9fr);
}

.stat-card,
.card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 18px 42px var(--shadow);
    backdrop-filter: blur(18px);
}

.stat-card {
    padding: 18px;
    position: relative;
}

.stat-icon {
    position: absolute;
    top: 16px;
    right: 18px;
    font-size: 24px;
    opacity: 0.22;
}

.stat-label {
    margin-bottom: 8px;
    color: var(--text-secondary);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
}

.stat-value {
    font-size: 32px;
    font-weight: 800;
}

.card {
    padding: 22px;
}

.card-header {
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
}

.card-title {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
}

.muted {
    color: var(--text-secondary);
    margin: 6px 0 0;
}

.hero-card {
    margin-bottom: 20px;
}

.hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) repeat(3, minmax(0, 1fr));
    gap: 16px;
}

.hero-main h2 {
    margin: 0 0 10px;
    font-size: 28px;
}

.hero-main p {
    margin: 0;
    color: var(--text-secondary);
}

.pill-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 14px;
}

.pill,
.badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid transparent;
}

.pill {
    color: var(--text-primary);
    background: rgba(148, 163, 184, 0.08);
    border-color: var(--border);
}

.badge-healthy {
    color: #a7f3d0;
    background: rgba(16, 185, 129, 0.14);
    border-color: rgba(16, 185, 129, 0.28);
}

.badge-attention {
    color: #fde68a;
    background: rgba(245, 158, 11, 0.16);
    border-color: rgba(245, 158, 11, 0.28);
}

.badge-failing {
    color: #fecdd3;
    background: rgba(244, 63, 94, 0.16);
    border-color: rgba(244, 63, 94, 0.28);
}

.badge-pending,
.badge-neutral {
    color: #bae6fd;
    background: rgba(56, 189, 248, 0.16);
    border-color: rgba(56, 189, 248, 0.28);
}

.tab-bar {
    display: flex;
    gap: 10px;
    margin-bottom: 18px;
}

.tab-button {
    padding: 10px 14px;
    color: var(--text-secondary);
    background: rgba(148, 163, 184, 0.08);
}

.tab-button.active,
.tab-button:hover {
    color: var(--text-primary);
    background: linear-gradient(135deg, rgba(109, 94, 252, 0.24), rgba(20, 184, 166, 0.16));
    border-color: rgba(109, 94, 252, 0.35);
}

.panel {
    display: none;
}

.panel.active {
    display: block;
}

.toolbar {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
}

.toolbar-group {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
}

.checkbox-inline {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-secondary);
    font-size: 13px;
}

.loading-state,
.empty-state {
    display: grid;
    place-items: center;
    min-height: 120px;
    color: var(--text-secondary);
    text-align: center;
    border: 1px dashed rgba(148, 163, 184, 0.22);
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.42);
}

.intent-stack,
.service-stack,
.timeline-stack {
    display: grid;
    gap: 14px;
}

.intent-card,
.service-card,
.timeline-card,
.palette-card,
.intent-lane,
.inspector-section {
    background: rgba(15, 23, 42, 0.55);
    border: 1px solid var(--border);
    border-radius: 16px;
}

.intent-card,
.service-card,
.timeline-card {
    padding: 16px;
}

.intent-card-header,
.service-card-header,
.timeline-head {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
}

.intent-card-header h3,
.service-card-header h3,
.timeline-head h3 {
    margin: 0;
    font-size: 16px;
}

.asset-grid {
    display: grid;
    gap: 10px;
    margin-top: 14px;
}

.asset-chip {
    padding: 12px;
    border-radius: 14px;
    background: rgba(30, 41, 59, 0.7);
    border: 1px solid rgba(148, 163, 184, 0.16);
}

.asset-chip-top {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
}

.asset-chip-title {
    font-weight: 700;
}

.asset-chip-type {
    color: var(--text-secondary);
    font-size: 12px;
}

.asset-chip-type-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
}

.asset-chip-category {
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    color: var(--text-secondary);
    background: rgba(15, 23, 42, 0.78);
    border: 1px solid rgba(148, 163, 184, 0.16);
}

.intent-asset-group {
    margin-top: 14px;
}

.intent-asset-group-title {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    font-size: 12px;
    font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.fact-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
}

.fact {
    padding: 5px 8px;
    border-radius: 10px;
    font-size: 12px;
    color: var(--text-secondary);
    background: rgba(15, 23, 42, 0.7);
    border: 1px solid rgba(148, 163, 184, 0.14);
}

.timeline-card {
    border-left: 3px solid rgba(109, 94, 252, 0.55);
}

.timeline-meta {
    margin-top: 8px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    color: var(--text-secondary);
    font-size: 12px;
}

.timeline-assets {
    display: grid;
    gap: 10px;
    margin-top: 14px;
}

.timeline-asset {
    padding: 12px;
    border-radius: 14px;
    background: rgba(15, 23, 42, 0.65);
    border: 1px solid rgba(148, 163, 184, 0.14);
}

.timeline-asset-logs {
    margin-top: 10px;
    display: grid;
    gap: 6px;
}

.timeline-log {
    padding: 8px 10px;
    border-radius: 10px;
    background: rgba(30, 41, 59, 0.8);
    font-size: 12px;
    color: var(--text-secondary);
}

.topology-canvas {
    min-height: 620px;
    overflow: auto;
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.48);
    padding: 18px;
}

.topology-svg {
    width: 100%;
    min-height: 580px;
}

.topology-node rect,
.topology-node path {
    fill: rgba(15, 23, 42, 0.92);
    stroke: rgba(148, 163, 184, 0.22);
    stroke-width: 1.2;
}

.topology-node.partition rect {
    fill: rgba(240, 228, 66, 0.14);
    stroke: rgba(240, 228, 66, 0.36);
}

.topology-node.intent rect {
    fill: rgba(204, 121, 167, 0.14);
    stroke: rgba(204, 121, 167, 0.32);
}

.topology-node.asset rect {
    fill: rgba(15, 23, 42, 0.92);
}

.topology-node text {
    font-size: 12px;
    fill: var(--text-primary);
}

.topology-edge {
    fill: none;
    stroke: rgba(148, 163, 184, 0.4);
    stroke-width: 1.4;
}

.topology-edge.join {
    stroke: rgba(109, 94, 252, 0.75);
}

.topology-edge.dependsOn {
    stroke: rgba(20, 184, 166, 0.75);
}

.topology-edge.outputRef {
    stroke: rgba(245, 158, 11, 0.75);
    stroke-dasharray: 8 6;
}

.builder-card {
    min-height: 680px;
}

.asset-palette {
    display: grid;
    gap: 12px;
}

.palette-card {
    padding: 14px;
    cursor: grab;
}

.palette-card,
.builder-partition-card,
.intent-lane,
.builder-asset {
    position: relative;
    overflow: hidden;
}

.palette-card::before,
.builder-partition-card::before,
.intent-lane::before,
.builder-asset::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
        radial-gradient(circle at 18px 14px, rgba(226, 232, 240, 0.09) 0 6px, transparent 6.5px) 0 0 / 42px 30px,
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 34%);
    opacity: 0.7;
}

.palette-card:hover {
    border-color: rgba(109, 94, 252, 0.35);
}

.palette-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
}

.palette-meta {
    margin-top: 8px;
    color: var(--text-secondary);
    font-size: 13px;
}

.builder-canvas {
    display: grid;
    gap: 14px;
}

.builder-partition-card {
    padding: 16px;
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.62);
    border: 1px solid rgba(109, 94, 252, 0.22);
    cursor: pointer;
}

.builder-intents {
    display: grid;
    gap: 14px;
}

.intent-lane {
    padding: 14px;
    cursor: grab;
}

.intent-lane-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
}

.intent-assets {
    display: grid;
    gap: 10px;
    min-height: 60px;
}

.builder-asset {
    padding: 12px;
    border-radius: 12px;
    background: rgba(30, 41, 59, 0.8);
    border: 1px solid rgba(148, 163, 184, 0.14);
    cursor: grab;
}

.builder-asset.selected,
.intent-lane.selected,
.builder-partition-card.selected {
    border-color: rgba(109, 94, 252, 0.45);
    box-shadow: 0 0 0 2px rgba(109, 94, 252, 0.16);
}

.drop-target {
    border-color: rgba(20, 184, 166, 0.6);
    background: rgba(20, 184, 166, 0.08);
}

.inspector-panel {
    display: grid;
    gap: 16px;
}

.inspector-section {
    padding: 14px;
}

.form-grid {
    display: grid;
    gap: 12px;
}

.form-grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
}

.field {
    display: grid;
    gap: 6px;
}

.field label {
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
}

.builder-textarea {
    min-height: 130px;
    resize: vertical;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
}

.checkbox-stack {
    display: grid;
    gap: 8px;
}

.checkbox-card {
    padding: 10px 12px;
    border-radius: 12px;
    background: rgba(15, 23, 42, 0.68);
    border: 1px solid rgba(148, 163, 184, 0.14);
}

.toast-container {
    position: fixed;
    right: 20px;
    bottom: 20px;
    display: grid;
    gap: 10px;
    z-index: 40;
}

.toast {
    padding: 12px 14px;
    border-radius: 14px;
    min-width: 220px;
    background: rgba(15, 23, 42, 0.92);
    border: 1px solid var(--border);
    box-shadow: 0 14px 32px var(--shadow);
}

.toast.success {
    border-color: rgba(16, 185, 129, 0.3);
}

.toast.error {
    border-color: rgba(244, 63, 94, 0.3);
}

@media (max-width: 1600px) {
    .summary-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .builder-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 1180px) {
    .sidebar {
        position: static;
        width: 100%;
        height: auto;
    }

    .layout {
        display: block;
    }

    .main {
        margin-left: 0;
    }

    .two-col,
    .hero-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 780px) {
    .summary-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .form-grid.two {
        grid-template-columns: 1fr;
    }

    .toolbar,
    .header {
        flex-direction: column;
    }
}

:root {
    --bg-base:     #0f172a;
    --bg-surface:  rgba(15, 23, 42, 0.78);
    --bg-elevated: rgba(15, 23, 42, 0.92);
    --bg-overlay:  rgba(30, 41, 59, 0.94);
    --border:        rgba(148, 163, 184, 0.2);
    --border-muted:  rgba(148, 163, 184, 0.12);
    --border-accent: rgba(109, 94, 252, 0.45);
    --text-primary:   #e2e8f0;
    --text-secondary: #94a3b8;
    --text-muted:     #64748b;
    --text-subtle:    #64748b;
    --status-healthy:     #10b981;
    --status-progressing: #38bdf8;
    --status-degraded:    #f43f5e;
    --status-suspended:   #94a3b8;
    --status-unknown:     #94a3b8;
    --status-missing:     #f59e0b;
    --node-partition:   #f0e442;
    --node-intent:      #cc79a7;
    --node-runtime:     #0072b2;
    --node-config:      #009e73;
    --node-storage:     #56b4e9;
    --node-traffic:     #d55e00;
    --sync-synced:    #10b981;
    --sync-outofsync: #f59e0b;
    --brand:        #6d5efc;
    --brand-hover:  #5547d7;
    --accent:       #14b8a6;
    --accent-light: #5eead4;
    --accent-hover: #0f9d8a;
    --accent-subtle: rgba(20, 184, 166, 0.16);
    --blue:   #38bdf8;
    --teal:   #14b8a6;
    --cyan:   #22d3ee;
    --green:  #10b981;
    --amber:  #f59e0b;
    --red:    #f43f5e;
    --purple: #6d5efc;
    --primary:      var(--brand);
    --primary-dark: var(--brand-hover);
    --secondary:    var(--status-healthy);
    --success:      var(--status-healthy);
    --danger:       var(--status-degraded);
    --warning:      var(--status-missing);
    --info:         var(--status-progressing);
    --bg-card:       var(--bg-surface);
    --bg-card-strong: var(--bg-elevated);
    --shadow:        rgba(2, 6, 23, 0.5);
    --gradient: radial-gradient(1200px circle at 20% -10%, rgba(109, 94, 252, 0.28), transparent 40%),
                radial-gradient(1200px circle at 90% 10%, rgba(20, 184, 166, 0.22), transparent 45%),
                linear-gradient(180deg, #0b1120 0%, #0f172a 100%);
    --radius-sm: 3px;
    --radius:    6px;
    --radius-lg: 8px;
}

html,
body {
    min-height: 100%;
    background: var(--gradient);
}

body {
    background: var(--gradient);
    color: var(--text-primary);
    color-scheme: dark;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Inter", sans-serif;
}

::-webkit-scrollbar-track {
    background: transparent;
}

::-webkit-scrollbar-thumb {
    background: rgba(110, 118, 129, 0.45);
    border-radius: 999px;
}

.sidebar {
    width: 240px;
    padding: 0;
    background: var(--bg-surface);
    border-right: 1px solid var(--border);
    backdrop-filter: none;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px;
    margin-bottom: 0;
    border-bottom: 1px solid var(--border-muted);
}

.logo-mark {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0;
    border-radius: var(--radius);
    background: linear-gradient(135deg, #e96d2b 0%, #f4a261 100%);
    border: 0;
    box-shadow: none;
}

.logo h1 {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    background: none;
    color: var(--text-primary);
    -webkit-text-fill-color: currentColor;
}

.logo p {
    margin: 2px 0 0;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
}

.nav {
    gap: 2px;
    margin-bottom: 0;
    padding: 10px 8px;
}

.nav-item,
.tab-button,
.action-button,
.ghost-button {
    border-radius: var(--radius);
    transition: background 0.12s ease, color 0.12s ease, border-color 0.12s ease, box-shadow 0.12s ease;
}

.nav-item {
    padding: 8px 10px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
}

.nav-item:hover,
.nav-item.active {
    color: var(--accent-light);
    background: var(--accent-subtle);
    border-color: transparent;
}

.sidebar-section {
    padding: 0 16px;
    margin-bottom: 18px;
}

.sidebar-heading,
.panel-eyebrow {
    margin: 0 0 6px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
}

.search-input,
.builder-input,
.builder-textarea,
.builder-select {
    border-radius: var(--radius);
    padding: 8px 10px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text-primary);
}

.search-input:focus,
.builder-input:focus,
.builder-textarea:focus,
.builder-select:focus {
    border-color: var(--accent-light);
    box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.18);
}

.ghost-button,
.action-button {
    padding: 7px 12px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text-primary);
}

.action-button {
    border-color: #f0883e;
    background: var(--brand);
    color: #fff;
}

.action-button:hover {
    background: var(--brand-hover);
    transform: none;
    box-shadow: none;
}

.action-button.secondary,
.ghost-button {
    background: var(--bg-elevated);
    border-color: var(--border);
    color: var(--text-primary);
}

.ghost-button:hover,
.action-button.secondary:hover {
    background: var(--bg-overlay);
    transform: none;
    box-shadow: none;
}

.sidebar-footer {
    border-top: 1px solid var(--border-muted);
    padding-top: 14px;
    padding-bottom: 14px;
}

.partition-list-item {
    background: var(--bg-base);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-lg);
}

.partition-list-item.active,
.partition-list-item:hover {
    background: var(--bg-elevated);
    border-color: var(--accent-light);
}

.main {
    margin-left: 240px;
    padding: 20px 24px;
    background: var(--bg-base);
}

.header h1 {
    font-size: 28px;
    letter-spacing: -0.02em;
}

.summary-grid,
.grid {
    gap: 16px;
}

.stat-card,
.card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: 0 12px 24px var(--shadow);
    backdrop-filter: none;
}

.stat-card {
    padding: 16px;
}

.card {
    padding: 18px;
}

.card-header {
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-muted);
}

.card-title,
.panel-title {
    margin: 0;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.02em;
}

.muted {
    color: var(--text-muted);
}

.pill,
.badge {
    padding: 4px 9px;
    border-radius: 999px;
    font-size: 11px;
}

.pill {
    color: var(--text-secondary);
    background: var(--bg-elevated);
    border-color: var(--border);
}

.badge-healthy {
    color: var(--green);
    background: rgba(63, 185, 80, 0.12);
    border-color: rgba(63, 185, 80, 0.28);
}

.badge-attention {
    color: var(--amber);
    background: rgba(210, 153, 34, 0.12);
    border-color: rgba(210, 153, 34, 0.28);
}

.badge-failing {
    color: var(--red);
    background: rgba(248, 81, 73, 0.12);
    border-color: rgba(248, 81, 73, 0.28);
}

.badge-pending,
.badge-neutral {
    color: var(--blue);
    background: rgba(88, 166, 255, 0.12);
    border-color: rgba(88, 166, 255, 0.24);
}

.tab-bar {
    gap: 0;
    margin-bottom: 0;
    border-bottom: 1px solid var(--border);
    padding: 0 8px;
}

.tab-button {
    padding: 10px 14px;
    font-size: 13px;
    background: transparent;
    color: var(--text-secondary);
    border-color: transparent;
    border-radius: 0;
    border-bottom: 2px solid transparent;
}

.tab-button.active {
    color: var(--text-primary);
    background: transparent;
    border-color: transparent;
    border-bottom-color: var(--accent-light);
}

.tab-button:hover:not(.active) {
    color: var(--text-primary);
    background: var(--bg-elevated);
    border-color: transparent;
}

.loading-state,
.empty-state {
    min-height: 120px;
    border: 1px dashed var(--border);
    border-radius: var(--radius-lg);
    background: rgba(13, 17, 23, 0.72);
    color: var(--text-muted);
}

.intent-card,
.service-card,
.timeline-card {
    background: var(--bg-base);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-lg);
}

.asset-chip,
.timeline-asset,
.timeline-log,
.fact {
    background: var(--bg-elevated);
    border-color: var(--border);
}

.timeline-card {
    border-left: 3px solid var(--border-accent);
}

.timeline-card[data-status="healthy"]  { border-left-color: var(--status-healthy); }
.timeline-card[data-status="failing"]  { border-left-color: var(--status-degraded); }
.timeline-card[data-status="attention"] { border-left-color: var(--status-missing); }

.builder-shell {
    display: grid;
    grid-template-columns: 320px minmax(0, 1fr) 300px;
    min-height: 760px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
}

.builder-sidebar,
.builder-inspector-shell {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    overflow: hidden;
}

.builder-sidebar {
    border-right: 1px solid var(--border);
}

.builder-inspector-shell {
    border-left: 1px solid var(--border);
}

.builder-sidebar-header,
.builder-workspace-header,
.builder-inspector-header,
.topology-shell-header {
    padding: 16px 18px;
    border-bottom: 1px solid var(--border);
}

.builder-quick-start {
    padding: 16px 16px 0;
}

.builder-guide {
    margin-top: auto;
    padding: 16px;
}

.guide-stack {
    display: grid;
    gap: 12px;
}

.builder-section-heading,
.topology-side-title,
.topology-legend-heading,
.topology-detail-heading {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
}

.builder-section-copy {
    margin-bottom: 10px;
    color: var(--text-secondary);
    font-size: 12px;
    line-height: 1.6;
}

.quick-start-grid {
    display: grid;
    gap: 8px;
}

.quick-start-card {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-elevated);
    color: var(--text-primary);
    text-align: left;
}

.quick-start-card:hover {
    background: var(--bg-overlay);
    border-color: var(--accent-light);
}

.quick-start-icon,
.palette-icon,
.builder-asset-icon,
.topology-detail-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    flex-shrink: 0;
}

.quick-start-body {
    display: grid;
    gap: 2px;
}

.quick-start-body strong {
    font-size: 12px;
}

.quick-start-body span {
    font-size: 11px;
    line-height: 1.5;
    color: var(--text-secondary);
}

.asset-palette {
    display: grid;
    gap: 16px;
    padding: 16px;
    overflow-y: auto;
}

.library-section {
    display: grid;
    gap: 8px;
}

.library-section-title {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
}

.library-section-description {
    font-size: 11px;
    line-height: 1.5;
    color: var(--text-secondary);
}

.library-section-items {
    display: grid;
    gap: 8px;
}

.palette-card,
.builder-partition-card,
.intent-lane,
.builder-asset {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    box-shadow: 0 10px 16px rgba(0, 0, 0, 0.14);
}

.palette-card::before,
.builder-partition-card::before,
.intent-lane::before,
.builder-asset::before {
    display: none;
}

.palette-card {
    padding: 12px;
    border-left: 3px solid var(--asset-accent);
    cursor: grab;
}

.palette-card-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 8px;
}

.palette-title {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    min-width: 0;
}

.palette-title-block {
    display: grid;
    gap: 2px;
    min-width: 0;
}

.palette-title-text {
    font-weight: 600;
    color: var(--text-primary);
}

.palette-kicker {
    font-size: 11px;
    color: var(--text-muted);
}

.palette-meta {
    margin-top: 0;
    color: var(--text-secondary);
    font-size: 12px;
    line-height: 1.55;
}

.palette-hint {
    margin-top: 8px;
    color: var(--text-muted);
    font-size: 11px;
}

.palette-add-button {
    flex-shrink: 0;
    padding: 4px 8px;
    font-size: 11px;
}

.guide-card {
    display: grid;
    gap: 8px;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-elevated);
    color: var(--text-secondary);
    font-size: 12px;
}

.guide-focus-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary);
}

.guide-line {
    display: flex;
    gap: 8px;
    align-items: flex-start;
}

.guide-swatch {
    width: 18px;
    height: 2px;
    margin-top: 8px;
    border-radius: 999px;
    flex-shrink: 0;
}

.accent-runtime {
    background: var(--node-runtime);
}

.accent-network {
    background: repeating-linear-gradient(90deg, var(--node-traffic) 0, var(--node-traffic) 4px, transparent 4px, transparent 6px);
}

.accent-config {
    background: repeating-linear-gradient(90deg, var(--node-config) 0, var(--node-config) 4px, transparent 4px, transparent 7px);
}

.guide-note {
    padding-top: 8px;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 11px;
}

.builder-workspace {
    display: flex;
    flex-direction: column;
    min-width: 0;
    background: var(--bg-base);
}

.builder-breadcrumb {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 18px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-surface);
    min-height: 48px;
    flex-shrink: 0;
}

.bc-path {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-wrap: wrap;
    min-width: 0;
}

.bc-segment {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 9px;
    border-radius: var(--radius);
    border: 1px solid transparent;
    transition: background 0.12s, border-color 0.12s;
    user-select: none;
}

.bc-segment.bc-ancestor {
    cursor: pointer;
    color: var(--text-secondary);
}

.bc-segment.bc-ancestor:hover {
    background: var(--bg-elevated);
    border-color: var(--border);
    color: var(--text-primary);
}

.bc-segment.bc-current {
    background: var(--accent-subtle);
    border-color: var(--border-accent);
    color: var(--text-primary);
}

.bc-icon {
    font-size: 13px;
    flex-shrink: 0;
    opacity: 0.8;
}

.bc-text {
    display: grid;
    gap: 1px;
    min-width: 0;
}

.bc-label {
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
}

.bc-sub {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
}

.bc-sep {
    color: var(--text-muted);
    font-size: 14px;
    padding: 0 1px;
    flex-shrink: 0;
    line-height: 1;
}

.bc-hint {
    color: var(--text-muted);
    font-size: 12px;
}

.bc-nav {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
}

.bc-nav-button {
    width: 28px;
    height: 28px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
}

.builder-step-bar {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-surface);
}

.builder-step {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-base);
}

.builder-step.is-complete {
    border-color: rgba(167, 139, 250, 0.28);
    background: rgba(124, 58, 237, 0.1);
}

.builder-step-index {
    width: 20px;
    height: 20px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated);
    color: var(--accent-light);
    font-size: 10px;
    font-weight: 700;
    flex-shrink: 0;
}

.builder-step-copy {
    display: grid;
    gap: 2px;
    font-size: 11px;
    color: var(--text-muted);
}

.builder-step-copy strong {
    font-size: 12px;
    color: var(--text-primary);
}

.builder-tutorial {
    padding: 16px 18px 0;
    background: var(--bg-base);
}

.tutorial-card {
    display: grid;
    gap: 14px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background:
        radial-gradient(circle at top right, rgba(167, 139, 250, 0.12), transparent 42%),
        linear-gradient(180deg, rgba(22, 27, 34, 0.96), rgba(13, 17, 23, 0.94));
    box-shadow: 0 12px 22px rgba(0, 0, 0, 0.18);
}

.tutorial-card.is-complete {
    border-color: rgba(63, 185, 80, 0.28);
}

.tutorial-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
}

.tutorial-header h3 {
    margin: 0 0 6px;
    font-size: 20px;
}

.tutorial-current-copy {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.6;
}

.tutorial-progress,
.tutorial-actions,
.intent-lane-controls {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.tutorial-step-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 10px;
}

.tutorial-step-button {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    width: 100%;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(13, 17, 23, 0.72);
    color: var(--text-primary);
    text-align: left;
}

.tutorial-step-button:hover,
.tutorial-step-button.is-current {
    border-color: rgba(167, 139, 250, 0.32);
    background: rgba(91, 33, 182, 0.18);
}

.tutorial-step-button.is-complete {
    border-color: rgba(63, 185, 80, 0.24);
}

.tutorial-step-number {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated);
    color: var(--accent-light);
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
}

.tutorial-step-body {
    display: grid;
    gap: 2px;
    min-width: 0;
}

.tutorial-step-body strong {
    font-size: 13px;
}

.tutorial-step-body span {
    color: var(--text-secondary);
    font-size: 12px;
    line-height: 1.5;
}

.tutorial-focus-note {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: 12px;
    line-height: 1.6;
}

.builder-canvas {
    flex: 1;
    display: grid;
    gap: 16px;
    padding: 18px;
    overflow: auto;
    background-image:
        linear-gradient(rgba(48, 54, 61, 0.24) 1px, transparent 1px),
        linear-gradient(90deg, rgba(48, 54, 61, 0.24) 1px, transparent 1px);
    background-size: 24px 24px;
    background-position: 0 0;
}

.builder-partition-card {
    padding: 16px 18px;
    border-left: 3px solid var(--node-partition);
    cursor: pointer;
}

.builder-partition-summary {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
}

.builder-partition-kicker,
.intent-lane-kicker {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 8px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
}

.builder-partition-card h3 {
    margin: 0 0 6px;
    font-size: 22px;
}

.builder-partition-stats {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.builder-intents {
    display: grid;
    gap: 14px;
}

.builder-lane-placeholder {
    display: grid;
    place-items: center;
    min-height: 220px;
    padding: 24px;
    border: 1px dashed var(--border);
    border-radius: var(--radius-lg);
    background: rgba(13, 17, 23, 0.6);
    color: var(--text-muted);
    text-align: center;
}

.intent-lane {
    padding: 16px;
    border-left: 3px solid var(--node-intent);
    cursor: grab;
}

.intent-lane.selected,
.builder-partition-card.selected,
.builder-asset.selected {
    border-color: var(--accent-light);
    box-shadow: 0 0 0 2px rgba(167, 139, 250, 0.18);
}

.intent-lane-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 14px;
}

.intent-lane-summary strong {
    display: block;
    margin-bottom: 4px;
    font-size: 16px;
}

.intent-lane-guidance {
    margin: 0 0 12px;
    color: var(--text-secondary);
    font-size: 12px;
    line-height: 1.6;
}

.intent-lane-groups {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
}

.intent-lane-group {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: 11px;
    font-weight: 600;
}

.intent-lane-group.is-empty {
    font-weight: 500;
}

.intent-lane-group-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    flex-shrink: 0;
}

.intent-lane-index {
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-subtle);
    color: var(--accent-light);
    font-size: 10px;
}

.intent-lane-toolbar {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    justify-content: flex-end;
    flex-wrap: wrap;
}

.intent-assets {
    display: grid;
    gap: 10px;
    min-height: 72px;
}

.intent-assets.is-empty {
    border: 1px dashed var(--border);
    border-radius: 10px;
    background: rgba(13, 17, 23, 0.55);
}

.intent-assets-placeholder {
    padding: 18px;
    color: var(--text-muted);
    text-align: center;
    font-size: 12px;
}

.drop-target {
    border-color: var(--teal) !important;
    background: rgba(45, 212, 191, 0.08);
}

.builder-asset {
    padding: 12px;
    cursor: grab;
    border-left: 3px solid var(--asset-accent);
}

.builder-asset-meta {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
}

.builder-asset-move-hint,
.intent-lane-footer-copy {
    color: var(--text-muted);
    font-size: 11px;
    line-height: 1.5;
}

.builder-asset-head {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 10px;
}

.builder-asset-title {
    display: grid;
    gap: 2px;
    min-width: 0;
}

.builder-asset-title strong {
    font-size: 14px;
}

.builder-asset-title span {
    font-size: 12px;
    color: var(--text-muted);
}

.builder-asset-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

.intent-lane-footer {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border-muted);
}

.builder-preview-shell {
    border-top: 1px solid var(--border);
    background: var(--bg-surface);
}

.builder-preview-toggle {
    width: 100%;
    padding: 10px 14px;
    border: 0;
    border-bottom: 1px solid var(--border-muted);
    background: transparent;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
}

.builder-preview-toggle:disabled {
    cursor: default;
    opacity: 0.55;
}

.builder-preview {
    margin: 0;
    padding: 14px 16px;
    max-height: 240px;
    overflow: auto;
    background: var(--bg-base);
    color: var(--text-secondary);
    font-size: 12px;
    line-height: 1.6;
    white-space: pre;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
}

.builder-preview.is-collapsed {
    display: none;
}

.inspector-panel {
    flex: 1;
    padding: 16px;
    overflow: auto;
    display: grid;
    gap: 14px;
    background: var(--bg-surface);
}

.inspector-section {
    padding: 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-base);
}

.inspector-section h3 {
    margin: 0 0 14px;
    font-size: 16px;
}

.field label {
    font-size: 11px;
    color: var(--text-secondary);
}

.field-hint {
    margin-top: 6px;
    color: var(--text-muted);
    font-size: 11px;
    line-height: 1.5;
}

.checkbox-card {
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-base);
}

.tutorial-focus-target {
    border-color: rgba(167, 139, 250, 0.46) !important;
    box-shadow: 0 0 0 2px rgba(167, 139, 250, 0.16), 0 14px 28px rgba(0, 0, 0, 0.2);
}

.topology-shell {
    display: flex;
    flex-direction: column;
    min-height: 760px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
}

.topology-shell-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
}

.topology-stage {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    flex: 1;
    min-height: 0;
}

.topology-controls {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-end;
}

.topology-filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
    align-items: flex-start;
}

.topology-zoom-controls {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-elevated);
}

.topology-zoom-button {
    width: 28px;
    height: 28px;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-surface);
    color: var(--text-primary);
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
}

.topology-zoom-button:hover:not(:disabled) {
    background: var(--bg-overlay);
}

.topology-zoom-button:disabled {
    opacity: 0.45;
    cursor: not-allowed;
}

.topology-zoom-value {
    min-width: 52px;
    text-align: center;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
}

.checkbox-inline {
    padding: 7px 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-elevated);
    color: var(--text-secondary);
    font-size: 12px;
}

.checkbox-inline input {
    accent-color: var(--accent-light);
}

.topology-canvas-shell {
    min-width: 0;
    padding: 18px;
    border-right: 1px solid var(--border);
    background: var(--bg-base);
}

.topology-canvas {
    height: 100%;
    min-height: 620px;
    overflow: auto;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(22, 27, 34, 0.8), rgba(13, 17, 23, 0.9));
}

.topology-svg-frame {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-width: 100%;
    min-height: 100%;
}

.topology-svg {
    display: block;
    max-width: none;
    min-height: 0;
    flex: none;
}

.topology-node {
    cursor: pointer;
}

.topology-node-card {
    fill: var(--bg-surface);
    stroke: var(--border);
    stroke-width: 1.4;
}

.topology-node.selected .topology-node-card {
    stroke: var(--accent-light);
    stroke-width: 1.6;
}

.topology-node-title {
    font-size: 12px;
    font-weight: 700;
    fill: var(--text-primary);
}

.topology-node-subtitle {
    font-size: 11px;
    fill: var(--text-secondary);
}

.topology-node-description {
    font-size: 11px;
    fill: var(--text-muted);
}

.topology-edge {
    fill: none;
    stroke: rgba(139, 148, 158, 0.42);
    stroke-width: 1.5;
}

.topology-edge.contains {
    stroke: rgba(139, 148, 158, 0.34);
}

.topology-edge.join {
    stroke: var(--accent-light);
    stroke-dasharray: 5 4;
}

.topology-edge.dependsOn {
    stroke: var(--teal);
    stroke-dasharray: 4 4;
}

.topology-edge.outputRef {
    stroke: var(--amber);
    stroke-dasharray: 8 5;
}

.topology-edge-label {
    font-size: 10px;
    text-anchor: middle;
    fill: var(--text-muted);
}

.topology-rail {
    display: grid;
    gap: 16px;
    align-content: start;
    padding: 18px;
    overflow: auto;
    background: var(--bg-surface);
}

.topology-side-card {
    display: grid;
    gap: 12px;
    padding: 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-base);
}

.topology-legend {
    display: grid;
    gap: 14px;
}

.topology-legend-group {
    display: grid;
    gap: 8px;
}

.topology-legend-item {
    display: flex;
    gap: 8px;
    align-items: center;
    color: var(--text-secondary);
    font-size: 12px;
}

.topology-legend-swatch {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--legend-color);
    border: 1px solid rgba(226, 232, 240, 0.28);
    box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.28);
    flex-shrink: 0;
}

.topology-edge-swatch {
    width: 18px;
    height: 0;
    border-top: 2px solid rgba(139, 148, 158, 0.42);
    flex-shrink: 0;
}

.topology-edge-swatch.join {
    border-top-color: var(--accent-light);
    border-top-style: dashed;
}

.topology-edge-swatch.dependsOn {
    border-top-color: var(--teal);
    border-top-style: dashed;
}

.topology-edge-swatch.outputRef {
    border-top-color: var(--amber);
    border-top-style: dashed;
}

.topology-details {
    display: grid;
    gap: 12px;
}

.topology-detail-card {
    display: grid;
    gap: 12px;
    border-left: 3px solid var(--node-accent);
}

.topology-detail-header {
    display: flex;
    gap: 12px;
    align-items: flex-start;
}

.topology-detail-header h3 {
    margin: 0 0 4px;
    font-size: 18px;
}

.topology-detail-header p,
.topology-detail-copy {
    margin: 0;
    color: var(--text-secondary);
    font-size: 13px;
    line-height: 1.6;
}

.topology-detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

.topology-detail-block {
    display: grid;
    gap: 8px;
}

.topology-detail-list {
    display: grid;
    gap: 8px;
}

.topology-detail-row {
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr) auto;
    gap: 8px;
    align-items: center;
    padding: 8px 10px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-surface);
    font-size: 12px;
}

.topology-detail-direction {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
}

.topology-detail-name {
    color: var(--text-primary);
    font-weight: 600;
}

.topology-detail-kind {
    color: var(--text-secondary);
}

@media (max-width: 1600px) {
    .builder-shell {
        grid-template-columns: 280px minmax(0, 1fr) 280px;
    }

    .topology-stage {
        grid-template-columns: minmax(0, 1fr) 280px;
    }

    .builder-step-bar {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 1280px) {
    .builder-shell,
    .topology-stage {
        grid-template-columns: 1fr;
    }

    .builder-sidebar {
        border-right: 0;
        border-bottom: 1px solid var(--border);
    }

    .builder-inspector-shell {
        border-left: 0;
        border-top: 1px solid var(--border);
    }

    .topology-canvas-shell {
        border-right: 0;
        border-bottom: 1px solid var(--border);
    }

    .tutorial-header,
    .tutorial-focus-note {
        flex-direction: column;
    }
}

@media (max-width: 1180px) {
    .sidebar {
        position: static;
        width: 100%;
        height: auto;
    }

    .layout {
        display: block;
    }

    .main {
        margin-left: 0;
    }

    .two-col,
    .hero-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 780px) {
    .builder-step-bar {
        grid-template-columns: 1fr;
    }

    .builder-partition-summary,
    .intent-lane-header,
    .topology-shell-header,
    .topology-filter-row {
        flex-direction: column;
    }

    .topology-filter-row {
        justify-content: flex-start;
    }

    .topology-controls {
        align-items: flex-start;
    }

    .header-actions,
    .header-context-pills,
    .tutorial-actions,
    .intent-lane-controls,
    .intent-lane-footer,
    .builder-asset-meta {
        flex-direction: column;
        align-items: stretch;
    }
}

/* ══════════════════════════════════════════════════════════
   ARGO-STYLE APP TILE GRID
   ════════════════════════════════════════════════════════ */

.app-grid-section {
    padding: 16px 24px 20px;
}

.app-grid-toolbar {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    flex-wrap: wrap;
}

.app-grid-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--text-muted);
    flex: 1;
}

.app-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
}

/* ArgoCD-inspired application tile */
.app-tile {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
    position: relative;
}

.app-tile:hover {
    border-color: rgba(240, 246, 252, 0.22);
    box-shadow: 0 4px 16px var(--shadow);
}

.app-tile.active {
    border-color: var(--border-accent);
    box-shadow: 0 0 0 2px rgba(56, 139, 253, 0.14);
}

/* coloured health stripe at the top of each tile */
.app-tile::before {
    content: "";
    display: block;
    height: 3px;
    background: var(--status-unknown);
    flex-shrink: 0;
}

.app-tile[data-health="healthy"]::before    { background: var(--status-healthy); }
.app-tile[data-health="attention"]::before  { background: var(--status-missing); }
.app-tile[data-health="failing"]::before    { background: var(--status-degraded); }
.app-tile[data-health="pending"]::before    { background: var(--status-progressing); }

.app-tile-body {
    padding: 14px 16px 14px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.app-tile-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    word-break: break-all;
}

.app-tile-status-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
}

.app-tile-labels {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
}

.app-tile-label {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    color: var(--text-secondary);
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(148, 163, 184, 0.12);
}

.app-tile-meta {
    display: flex;
    gap: 14px;
    font-size: 12px;
    color: var(--text-muted);
    padding-top: 10px;
    border-top: 1px solid var(--border-muted);
    flex-wrap: wrap;
}

.app-tile-meta-item {
    display: flex;
    align-items: center;
    gap: 4px;
}

/* ══════════════════════════════════════════════════════════
   ARGO-STYLE STATUS INDICATORS
   ════════════════════════════════════════════════════════ */

.status-row {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
}

.status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
}

.status-dot-healthy    { background: var(--status-healthy); }
.status-dot-attention  { background: var(--status-missing); }
.status-dot-failing    { background: var(--status-degraded); }
.status-dot-neutral    { background: var(--status-unknown); }
.status-dot-pending    {
    background: var(--status-progressing);
    animation: argo-pulse 1.6s ease-out infinite;
}

@keyframes argo-pulse {
    0%   { box-shadow: 0 0 0 0   rgba(13, 173, 234, 0.5); }
    70%  { box-shadow: 0 0 0 5px rgba(13, 173, 234, 0); }
    100% { box-shadow: 0 0 0 0   rgba(13, 173, 234, 0); }
}

.status-label-healthy   { color: var(--status-healthy); }
.status-label-attention { color: var(--status-missing); }
.status-label-failing   { color: var(--status-degraded); }
.status-label-pending   { color: var(--status-progressing); }
.status-label-neutral   { color: var(--text-muted); }

/* ══════════════════════════════════════════════════════════
   PANEL PADDING (panels now share left/right with header)
   ════════════════════════════════════════════════════════ */

.panel.active {
    padding: 20px 24px;
}

/* Hero card outside panels — align with grid padding */
#selectedPartitionHero {
    margin: 0 24px 16px;
}

/* Overview panel: no extra top padding since app-grid-section handles it */
#overviewPanel.active {
    padding-top: 0;
}
