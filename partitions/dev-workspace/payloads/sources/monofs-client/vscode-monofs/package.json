{
  "name": "monofs",
  "publisher": "radryc",
  "displayName": "MonoFS",
  "description": "MonoFS virtual monorepo workflow for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:monofs.workflow"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "monofs.buildBinaries",
        "title": "Build Binaries",
        "category": "MonoFS"
      },
      {
        "command": "monofs.bootstrapDeploy",
        "title": "Bootstrap Deploy",
        "category": "MonoFS"
      },
      {
        "command": "monofs.bootstrapStampUrls",
        "title": "Bootstrap Stamp URLs",
        "category": "MonoFS"
      },
      {
        "command": "monofs.releasePartitions",
        "title": "Release Partitions",
        "category": "MonoFS"
      },
      {
        "command": "monofs.portForwardStorage",
        "title": "Port-Forward Storage",
        "category": "MonoFS"
      },
      {
        "command": "monofs.ingestRepository",
        "title": "Ingest Repository",
        "category": "MonoFS"
      },
      {
        "command": "monofs.mountWorkspace",
        "title": "Mount Virtual Monorepo",
        "category": "MonoFS"
      },
      {
        "command": "monofs.openMountedWorkspace",
        "title": "Open MonoFS Workspace",
        "category": "MonoFS"
      },
      {
        "command": "monofs.sessionStatus",
        "title": "Session Status",
        "category": "MonoFS"
      },
      {
        "command": "monofs.sessionDiff",
        "title": "Session Diff",
        "category": "MonoFS"
      },
      {
        "command": "monofs.sessionCommit",
        "title": "Session Commit",
        "category": "MonoFS"
      },
      {
        "command": "monofs.sessionPull",
        "title": "Session Pull",
        "category": "MonoFS"
      },
      {
        "command": "monofs.sessionPush",
        "title": "Session Push Dependencies",
        "category": "MonoFS"
      },
      {
        "command": "monofs.sessionDiscard",
        "title": "Session Discard",
        "category": "MonoFS"
      },
      {
        "command": "monofs.openConfiguration",
        "title": "Open Configuration",
        "category": "MonoFS"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "monofs.workflow",
          "name": "MonoFS"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "monofs.mountWorkspace",
          "when": "view == monofs.workflow",
          "group": "navigation@1"
        },
        {
          "command": "monofs.openMountedWorkspace",
          "when": "view == monofs.workflow",
          "group": "navigation@2"
        },
        {
          "command": "monofs.sessionStatus",
          "when": "view == monofs.workflow",
          "group": "navigation@3"
        },
        {
          "command": "monofs.sessionCommit",
          "when": "view == monofs.workflow",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "MonoFS",
      "properties": {
        "monofs.repoPath": {
          "type": "string",
          "scope": "window",
          "default": "",
          "description": "Absolute path to the MonoFS repository checkout for local checkout workflows. If empty, the extension uses the current workspace when it looks like MonoFS, then falls back to the last detected MonoFS checkout."
        },
        "monofs.runtimeProfile": {
          "type": "string",
          "scope": "window",
          "default": "auto",
          "enum": [
            "auto",
            "localCheckout",
            "devWorkspacePartition"
          ],
          "description": "Select how the extension resolves defaults. auto detects the dev-workspace partition image and otherwise uses the local MonoFS checkout workflow."
        },
        "monofs.scriptsRepoPath": {
          "type": "string",
          "scope": "window",
          "default": "",
          "description": "Absolute path to the sibling scripts repository. If empty, the extension uses ../scripts relative to the MonoFS repo path."
        },
        "monofs.binaryDir": {
          "type": "string",
          "scope": "window",
          "default": "",
          "description": "Directory containing MonoFS binaries. If empty, the extension uses profile defaults such as <repoPath>/bin locally and /usr/local/bin in the dev-workspace partition."
        },
        "monofs.routerAddress": {
          "type": "string",
          "scope": "window",
          "default": "",
          "description": "MonoFS router address used by mount, ingest, and session commands. If empty, the extension uses a profile-specific default."
        },
        "monofs.mountPath": {
          "type": "string",
          "scope": "window",
          "default": "",
          "description": "Mount point for the writable MonoFS virtual monorepo workspace. If empty, the extension uses a profile-specific default."
        },
        "monofs.overlayPath": {
          "type": "string",
          "scope": "window",
          "default": "",
          "description": "Overlay directory for writable MonoFS state. Keep this outside the mount point. If empty, the extension uses a profile-specific default."
        },
        "monofs.cachePath": {
          "type": "string",
          "scope": "window",
          "default": "",
          "description": "Optional local cache directory for monofs-client. Keep this outside the mount point. If empty, the extension uses a profile-specific default. Set it explicitly to an empty string to disable cache."
        },
        "monofs.useExternalAddresses": {
          "type": "boolean",
          "scope": "window",
          "default": true,
          "description": "Pass --use-external-addrs when mounting MonoFS."
        },
        "monofs.defaultBranchStrategy": {
          "type": "string",
          "scope": "window",
          "default": "direct",
          "enum": [
            "direct",
            "workspace_branch",
            "per_repo_branch"
          ],
          "description": "Branch strategy used by MonoFS session commit."
        },
        "monofs.openMountInNewWindow": {
          "type": "boolean",
          "scope": "window",
          "default": true,
          "description": "Open the mounted workspace in a new VS Code window instead of replacing the current one."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
